# Build artifacts (produced by `task build`)
/wasmbox.wasm
/wasm_exec.js
/clients/hello/hello.wasm
/clients/dock/dock.wasm
/clients/quake/quake.wasm
/clients/dock/dock.wasm
/clients/dock/wasm_exec.js
/clients/terminal/terminal.wasm
/clients/files/files.wasm
/clients/code/code.wasm
/clients/showcase/showcase.wasm
/clients/calculator/calculator.wasm
/bin/
# Stray binaries from `go build` in the cmd/serve dir (Taskfile uses
# bin/wasmbox-serve; this catches accidental top-level builds).
/serve

# OCI pack prep artifacts (materialised by `task ociapps:prep:<app>`).
# clients/dock/sdk.js + clients/dock/wasm_exec.js are committed because the
# dock builds in isolation; the others are transient build-time copies.
/clients/hello/sdk.js
/clients/hello/wasm_exec.js
/clients/terminal/sdk.js
/clients/terminal/wasm_exec.js
/clients/files/sdk.js
/clients/files/wasm_exec.js
/clients/code/sdk.js
/clients/code/wasm_exec.js
/clients/showcase/sdk.js
/clients/showcase/wasm_exec.js
/clients/quake/wasm_exec.js

# Agent/CI test harness deps
/test/node_modules/

# Frame-matrix probe snapshot output — regenerated on every run,
# useful for local eyeballing, not for the tree.
/test/frame-matrix-out/
/test/theme-frame-matrix-out/

# Taskfile internal cache (per-task input/output checksums for
# `sources:` / `generates:` dependency tracking — local-only, no
# value to anyone else).
/.task/
